      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(order_service_http_request_duration_seconds_bucket[1m])) by (le))",
